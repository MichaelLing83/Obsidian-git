{
  "name": "vault-git-sync",
  "version": "1.3.0",
  "description": "Vault Git Sync plugin for Obsidian to perform git operations on your vault",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:coverage": "node scripts/run-test-coverage.mjs",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "git",
    "plugin"
  ],
  "author": "MichaelLing83",
  "license": "MIT",
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "isomorphic-git": "^1.37.5",
    "simple-git": "^3.32.3"
  }
}
